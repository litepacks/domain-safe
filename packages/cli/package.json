{
  "name": "domain-safe",
  "version": "0.1.1",
  "description": "CLI for offline domain reputation checks using downloadable blacklists",
  "license": "MIT",
  "type": "module",
  "bin": {
    "domain-safe": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@domain-safe/core": "workspace:*",
    "@domain-safe/sources": "workspace:*",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "vitest": "^2.1.8"
  }
}
